datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum ProductType {
  ONE_TIME
  SUBSCRIPTION
}

enum BillingInterval {
  DAY
  WEEK
  MONTH
  YEAR
}

enum PurchaseStatus {
  PENDING
  ACTIVE
  CANCELED
  EXPIRED
  REFUNDED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  workosUserId String? @unique
  createdAt DateTime @default(now())

  purchases UserProduct[]
  deviceTokens DeviceToken[]
  notificationSettings NotificationSettings?
  chatThreads ChatThread[]
  chatMessages ChatMessage[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        ProductType @default(ONE_TIME)

  /// Price in the smallest currency unit (e.g. cents)
  priceCents  Int
  currency    String      @default("USD")

  /// Only for SUBSCRIPTION products
  interval      BillingInterval?
  intervalCount Int             @default(1)

  isActive    Boolean  @default(true)
  createdAt DateTime @default(now())

  purchases UserProduct[]
}

/// Tracks which user purchased which product.
/// Works for both one-time purchases and subscriptions (use periodStart/periodEnd).
model UserProduct {
  id        String @id @default(cuid())
  userId    String
  productId String

  status PurchaseStatus @default(PENDING)

  quantity  Int    @default(1)
  priceCents Int
  currency  String @default("USD")

  purchasedAt DateTime @default(now())

  /// For subscriptions (optional for one-time purchases)
  periodStart DateTime?
  periodEnd   DateTime?

  /// Optional fields to link to payment provider records (Stripe, etc.)
  externalCustomerId     String?
  externalSubscriptionId String?
  externalInvoiceId      String?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([productId])
  @@index([userId, productId])
}

enum DevicePlatform {
  ANDROID
  IOS
  WEB
}

enum NotificationPreference {
  EMAIL_ONLY
  PUSH_ONLY
  BOTH
  NONE
}

enum ChatMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model DeviceToken {
  id         String         @id @default(cuid())
  userId     String
  platform   DevicePlatform
  token      String         @unique
  isActive   Boolean        @default(true)
  lastSeenAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, platform])
  @@index([userId, isActive])
}

model NotificationSettings {
  id                     String                 @id @default(cuid())
  userId                 String                 @unique
  preference             NotificationPreference @default(BOTH)
  timezone               String                 @default("UTC")
  quietHoursStartMin     Int?
  quietHoursEndMin       Int?
  reminderDefaultLeadMin Int                    @default(0)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  user                   User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatThread {
  id                 String      @id @default(cuid())
  userId             String
  title              String?
  lastMessageAt      DateTime?
  lastMessagePreview String?
  archivedAt         DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages           ChatMessage[]

  @@index([userId, updatedAt])
  @@index([userId, lastMessageAt])
}

model ChatMessage {
  id        String          @id @default(cuid())
  threadId  String
  userId    String
  role      ChatMessageRole
  content   String
  model     String?
  promptVer Int?
  tokensIn  Int?
  tokensOut Int?
  latencyMs Int?
  createdAt DateTime        @default(now())

  thread    ChatThread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([userId, createdAt])
}