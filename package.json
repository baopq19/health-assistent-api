{
  "name": "health-assistant-api",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun dist/index.js",
    "db:migrate": "bunx prisma migrate dev",
    "db:push": "bunx prisma db push",
    "db:studio": "bunx prisma studio",
    "db:generate": "bunx prisma generate"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.5.2",
    "prisma": "^7.6.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@prisma/client": "^7.6.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@trpc/server": "^11.16.0",
    "@workos-inc/node": "^7.0.0",
    "@workos/authkit-session": "^0.3.4",
    "@google/genai": "^1.12.0",
    "fastify": "^5.8.4",
    "pg": "^8.16.3",
    "zod": "^4.3.6"
  }
}
