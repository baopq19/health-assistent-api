##############################
# Core / Server
##############################
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

##############################
# Database (Postgres / Prisma)
##############################
DATABASE_URL="postgresql://myuser:mypassword@localhost:5432/mydb"

##############################
# WorkOS AuthKit (Phase 1)
##############################
# Required for @workos/authkit-session
WORKOS_CLIENT_ID="client_..."
WORKOS_API_KEY="sk_..."
WORKOS_REDIRECT_URI="http://localhost:3000/auth/callback"
# Must be >= 32 characters
WORKOS_COOKIE_PASSWORD="replace-with-a-32+char-secret-string"
# Optional
# WORKOS_COOKIE_NAME="auth_session"
# WORKOS_COOKIE_MAX_AGE="604800"
# WORKOS_COOKIE_DOMAIN="localhost"
# WORKOS_COOKIE_SAME_SITE="lax"

##############################
# R2 / S3 (Phase 2)
##############################
# R2_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
# R2_ACCESS_KEY_ID="..."
# R2_SECRET_ACCESS_KEY="..."
# R2_BUCKET="health-assistant"
# R2_REGION="auto"

##############################
# Upload limits (Phase 2)
##############################
# UPLOAD_MAX_BYTES="10485760"
# UPLOAD_ALLOWED_CONTENT_TYPES="application/pdf,image/png,image/jpeg"

##############################
# Google Gemini (Phases 3-4)
##############################
# GOOGLE_GENAI_API_KEY="..."
# GEMINI_OCR_MODEL="..."
# GEMINI_ADVICE_MODEL="..."
# GEMINI_OCR_PROMPT_VER="1"
# GEMINI_ADVICE_PROMPT_VER="1"

##############################
# Jobs / Scheduler (Phase 3+)
##############################
# JOB_WORKER_ID="local-dev"
# JOB_POLL_INTERVAL_SECONDS="5"
# REMINDER_SCAN_CRON="*/1 * * * *"
# CALENDAR_REMINDER_SCAN_CRON="*/5 * * * *"

##############################
# Resend (Phase 5)
##############################
# RESEND_API_KEY="..."
# EMAIL_FROM="Health Assistant <noreply@yourdomain.com>"

##############################
# Firebase Cloud Messaging (Phase 5)
##############################
# FCM_SERVICE_ACCOUNT_JSON_BASE64="..."

